<?xml version="1.0" encoding="UTF-8"?><!-- Use this file to deploy some handlers/chains and services      --><!-- Two ways to do this:                                           --><!--   java org.apache.axis.client.AdminClient deploy.wsdd          --><!--      after the axis server is running                          --><!-- or                                                             --><!--   java org.apache.axis.utils.Admin client|server deploy.wsdd   --><!--      from the same directory that the Axis engine runs         --><deployment xmlns="http://xml.apache.org/axis/wsdd/" xmlns:java="http://xml.apache.org/axis/wsdd/providers/java">

  <!-- Services from WebServicesService WSDL service -->

  <service name="WebServices" provider="java:RPC" style="wrapped" use="literal">
      <parameter name="wsdlTargetNamespace" value="http://service"/>
      <parameter name="wsdlServiceElement" value="WebServicesService"/>
      <parameter name="schemaQualified" value="http://service"/>
      <parameter name="wsdlServicePort" value="WebServices"/>
      <parameter name="className" value="service.WebServices"/>
      <parameter name="wsdlPortType" value="WebServices"/>
      <parameter name="typeMappingVersion" value="1.2"/>
      <operation xmlns:operNS="http://service" xmlns:retNS="http://service" xmlns:rtns="http://www.w3.org/2001/XMLSchema" name="getSpecificResearcher" qname="operNS:getSpecificResearcher" returnQName="retNS:getSpecificResearcherReturn" returnType="rtns:string" soapAction="">
        <parameter xmlns:pns="http://service" xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="pns:name" type="tns:string"/>
      </operation>
      <operation xmlns:operNS="http://service" xmlns:retNS="http://service" xmlns:rtns="http://www.w3.org/2001/XMLSchema" name="getResearchers" qname="operNS:getResearchers" returnQName="retNS:getResearchersReturn" returnType="rtns:string" soapAction="">
      </operation>
      <operation xmlns:operNS="http://service" xmlns:retNS="http://service" xmlns:rtns="http://www.w3.org/2001/XMLSchema" name="getSkillOwners" qname="operNS:getSkillOwners" returnQName="retNS:getSkillOwnersReturn" returnType="rtns:string" soapAction="">
        <parameter xmlns:pns="http://service" xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="pns:skill" type="tns:string"/>
      </operation>
      <parameter name="allowedMethods" value="getResearchers getSpecificResearcher getSkillOwners"/>

  </service>
</deployment>