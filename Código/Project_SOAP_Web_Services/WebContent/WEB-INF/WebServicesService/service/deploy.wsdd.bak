<!-- Use this file to deploy some handlers/chains and services      -->
<!-- Two ways to do this:                                           -->
<!--   java org.apache.axis.client.AdminClient deploy.wsdd          -->
<!--      after the axis server is running                          -->
<!-- or                                                             -->
<!--   java org.apache.axis.utils.Admin client|server deploy.wsdd   -->
<!--      from the same directory that the Axis engine runs         -->

<deployment
    xmlns="http://xml.apache.org/axis/wsdd/"
    xmlns:java="http://xml.apache.org/axis/wsdd/providers/java">

  <!-- Services from WebServicesService WSDL service -->

  <service name="WebServices" provider="java:RPC" style="wrapped" use="literal">
      <parameter name="wsdlTargetNamespace" value="http://service"/>
      <parameter name="wsdlServiceElement" value="WebServicesService"/>
      <parameter name="schemaQualified" value="http://service"/>
      <parameter name="wsdlServicePort" value="WebServices"/>
      <parameter name="className" value="service.WebServicesSoapBindingImpl"/>
      <parameter name="wsdlPortType" value="WebServices"/>
      <parameter name="typeMappingVersion" value="1.2"/>
      <operation name="getSpecificResearcher" qname="operNS:getSpecificResearcher" xmlns:operNS="http://service" returnQName="retNS:getSpecificResearcherReturn" xmlns:retNS="http://service" returnType="rtns:string" xmlns:rtns="http://www.w3.org/2001/XMLSchema" soapAction="" >
        <parameter qname="pns:name" xmlns:pns="http://service" type="tns:string" xmlns:tns="http://www.w3.org/2001/XMLSchema"/>
      </operation>
      <operation name="getResearchers" qname="operNS:getResearchers" xmlns:operNS="http://service" returnQName="retNS:getResearchersReturn" xmlns:retNS="http://service" returnType="rtns:string" xmlns:rtns="http://www.w3.org/2001/XMLSchema" soapAction="" >
      </operation>
      <operation name="getSkillOwners" qname="operNS:getSkillOwners" xmlns:operNS="http://service" returnQName="retNS:getSkillOwnersReturn" xmlns:retNS="http://service" returnType="rtns:string" xmlns:rtns="http://www.w3.org/2001/XMLSchema" soapAction="" >
        <parameter qname="pns:skill" xmlns:pns="http://service" type="tns:string" xmlns:tns="http://www.w3.org/2001/XMLSchema"/>
      </operation>
      <parameter name="allowedMethods" value="getResearchers getSpecificResearcher getSkillOwners"/>

  </service>
</deployment>
