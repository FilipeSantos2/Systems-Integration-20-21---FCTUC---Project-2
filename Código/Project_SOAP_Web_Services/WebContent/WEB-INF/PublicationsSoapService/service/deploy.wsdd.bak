<!-- Use this file to deploy some handlers/chains and services      -->
<!-- Two ways to do this:                                           -->
<!--   java org.apache.axis.client.AdminClient deploy.wsdd          -->
<!--      after the axis server is running                          -->
<!-- or                                                             -->
<!--   java org.apache.axis.utils.Admin client|server deploy.wsdd   -->
<!--      from the same directory that the Axis engine runs         -->

<deployment
    xmlns="http://xml.apache.org/axis/wsdd/"
    xmlns:java="http://xml.apache.org/axis/wsdd/providers/java">

  <!-- Services from PublicationsSoapService WSDL service -->

  <service name="PublicationsSoap" provider="java:RPC" style="wrapped" use="literal">
      <parameter name="wsdlTargetNamespace" value="http://service"/>
      <parameter name="wsdlServiceElement" value="PublicationsSoapService"/>
      <parameter name="schemaQualified" value="http://service"/>
      <parameter name="wsdlServicePort" value="PublicationsSoap"/>
      <parameter name="className" value="service.PublicationsSoapSoapBindingImpl"/>
      <parameter name="wsdlPortType" value="PublicationsSoap"/>
      <parameter name="typeMappingVersion" value="1.2"/>
      <operation name="getResearcherPublications" qname="operNS:getResearcherPublications" xmlns:operNS="http://service" returnQName="retNS:getResearcherPublicationsReturn" xmlns:retNS="http://service" returnType="rtns:string" xmlns:rtns="http://www.w3.org/2001/XMLSchema" soapAction="" >
        <parameter qname="pns:name" xmlns:pns="http://service" type="tns:string" xmlns:tns="http://www.w3.org/2001/XMLSchema"/>
      </operation>
      <operation name="getSpecificPublication" qname="operNS:getSpecificPublication" xmlns:operNS="http://service" returnQName="retNS:getSpecificPublicationReturn" xmlns:retNS="http://service" returnType="rtns:string" xmlns:rtns="http://www.w3.org/2001/XMLSchema" soapAction="" >
        <parameter qname="pns:title" xmlns:pns="http://service" type="tns:string" xmlns:tns="http://www.w3.org/2001/XMLSchema"/>
      </operation>
      <operation name="getPublications" qname="operNS:getPublications" xmlns:operNS="http://service" returnQName="retNS:getPublicationsReturn" xmlns:retNS="http://service" returnType="rtns:string" xmlns:rtns="http://www.w3.org/2001/XMLSchema" soapAction="" >
      </operation>
      <parameter name="allowedMethods" value="getResearcherPublications getPublications getSpecificPublication"/>

  </service>
</deployment>
